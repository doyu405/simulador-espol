}

.question{
    margin-top:35px;
    padding:20px;
    border-left:5px solid #004c99;
    background:#fafafa;
}

svg{
    background:white;
    border:1px solid #ccc;
    margin-top:15px;
}

input[type=text]{
    width:150px;
    padding:8px;
    font-size:16px;
}

button{
    padding:15px 30px;
    font-size:18px;
    border:none;
    border-radius:8px;
    background:#003366;
    color:white;
    cursor:pointer;
}

button:hover{
    background:#001f44;
}

.resultado{
    margin-top:30px;
    font-size:24px;
    font-weight:bold;
