<!-- ====================== -->
<!-- BOTÓN -->
<!-- ====================== -->

<div style="text-align:center;margin-top:40px;">

<button type="button" onclick="calificar()">
ENTREGAR EXAMEN
</button>

</div>

<div id="resultado" class="resultado"></div>

</form>

<script>

/* ===========================
   RESPUESTAS CORRECTAS
=========================== */

const respuestas = {

q1:"b",   // suma raíces = 6
q2:"b",   // vértice aprox (0,5)
q3:"d",   // 15
q4:"a",   // 1
q5:"c",   // 3 raíces

q6:"c",   // 4 raíces
q7:"a",   // pendiente negativa
q8:"c",   // x>=4
q9:"c",   // x=4
q10:"b"   // 2 asíntotas

};

/* ===========================
   CALIFICACIÓN
=========================== */

function calificar(){

let puntos = 0;

/* OPCIÓN MÚLTIPLE */

for(let i=1;i<=10;i++){

let seleccion =
document.querySelector(
`input[name="q${i}"]:checked`
);

if(
seleccion &&
seleccion.value === respuestas["q"+i]
){
puntos++;
}

}

/* RESOLUCIÓN */

if(
Number(document.getElementById("q11").value)==6
) puntos++;

if(
Number(document.getElementById("q12").value)==15
) puntos++;

if(
Number(document.getElementById("q13").value)==12
) puntos++;

if(
Number(document.getElementById("q14").value)==9
) puntos++;

if(
Number(document.getElementById("q15").value)==6
) puntos++;

if(
Number(document.getElementById("q16").value)==0
) puntos++;

if(
Number(document.getElementById("q17").value)==-10
) puntos++;

if(
Number(document.getElementById("q18").value)==5
) puntos++;

if(
Number(document.getElementById("q19").value)==2
) puntos++;

if(
Number(document.getElementById("q20").value)==2
) puntos++;


/* RESULTADO */

let nota = (puntos/20)*10;

document.getElementById("resultado").innerHTML=
`
<hr>
<h2>EXAMEN FINALIZADO</h2>

<p>
Preguntas correctas:
<b>${puntos}/20</b>
</p>

<p>
Calificación:
<b>${nota.toFixed(2)}/10</b>
</p>
`;

window.scrollTo(
0,
document.body.scrollHeight
);

}

/* ===========================
   TEMPORIZADOR 90 MIN
=========================== */

let tiempo = 90*60;

function actualizarTimer(){

let minutos =
Math.floor(tiempo/60);

let segundos =
tiempo%60;

document.getElementById("timer")
.innerHTML =
String(minutos).padStart(2,'0')
+
":"
+
String(segundos).padStart(2,'0');

if(tiempo<=0){

clearInterval(intervalo);

alert(
"Tiempo agotado. El examen será enviado automáticamente."
);

calificar();

return;
}

tiempo--;

}

actualizarTimer();

let intervalo =
setInterval(
actualizarTimer,
1000
);

</script>

